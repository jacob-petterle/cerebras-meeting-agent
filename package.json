{
  "name": "cerebras-meeting-agent",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "pnpm --filter @meeting-agent/server dev",
    "web": "pnpm --filter @meeting-agent/web dev",
    "web:debug": "pnpm --filter @meeting-agent/web dev:debug",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "overrides": {
      "onnxruntime-node": "1.21.0"
    }
  }
}
